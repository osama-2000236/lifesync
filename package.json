{
  "name": "lifesync",
  "version": "1.0.0",
  "description": "LifeSync — Smart Life Management System. AI-powered health and finance tracking via NLP.",
  "main": "server/app.js",
  "scripts": {
    "start": "node server/app.js",
    "dev": "nodemon server/app.js",
    "seed": "node server/seeders/seed.js",
    "migrate": "npx sequelize-cli db:migrate",
    "migrate:undo": "npx sequelize-cli db:migrate:undo:all",
    "test": "jest --verbose --forceExit",
    "test:watch": "jest --watch",
    "deploy": "wrangler deploy",
    "preview": "wrangler dev"
  },
  "keywords": [
    "health-tracking",
    "finance-management",
    "nlp",
    "openai",
    "express",
    "sequelize"
  ],
  "author": "LifeSync Team — Birzeit University",
  "license": "MIT",
  "nodemonConfig": {
    "watch": [
      "server/"
    ],
    "ext": "js,json",
    "ignore": [
      "node_modules/",
      "tests/"
    ]
  },
  "dependencies": {
    "axios": "^1.13.5",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "crypto-js": "^4.2.0",
    "dotenv": "^17.2.4",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "express-validator": "^7.3.1",
    "firebase-admin": "^13.6.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "mysql2": "^3.16.3",
    "nodemailer": "^8.0.1",
    "openai": "^6.18.0",
    "sequelize": "^6.37.7",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.0",
    "babel-jest": "^30.2.0",
    "jest": "^30.2.0",
    "nodemon": "^3.1.11",
    "sequelize-cli": "^6.6.5",
    "wrangler": "^4.78.0"
  }
}
