# ============================================
# LifeSync Environment Configuration
# Copy this file to .env and fill in values
# ============================================

# --- Server ---
NODE_ENV=development
PORT=5000

# --- MySQL Database ---
DB_HOST=localhost
DB_PORT=3306
DB_NAME=lifesync_db
DB_USER=root
DB_PASSWORD=your_mysql_password

# --- Firebase ---
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_PRIVATE_KEY_ID=your_private_key_id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=your_service_account@your_project.iam.gserviceaccount.com
FIREBASE_CLIENT_ID=your_client_id
FIREBASE_AUTH_URI=https://accounts.google.com/o/oauth2/auth
FIREBASE_TOKEN_URI=https://oauth2.googleapis.com/token

# --- JWT ---
JWT_SECRET=your_jwt_secret_key_min_32_chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_secret_key
JWT_REFRESH_EXPIRES_IN=30d

# ── AI Provider Selection ──────────────────────────────────────────────
# Default: private local conversation through Ollama. Docker Compose wires this
# automatically; for native development install Ollama and run `ollama serve`.
CHAT_AI_PROVIDER=ollama
INSIGHTS_AI_PROVIDER=ollama

# Custom HF endpoint
# Hosted Space example:
# CUSTOM_HF_ENDPOINT=https://os-1202883-lifesync-api.hf.space
# Local Gemma example:
CUSTOM_HF_ENDPOINT=http://127.0.0.1:7860
CUSTOM_HF_MODEL=google/gemma-4-E2B-it
HF_API_KEY=                          # optional — leave blank for public Space
HF_TOKEN=                            # optional — used by the local Gemma service for hub download/auth
HF_HUB_DISABLE_XET=1                # optional — useful if Xet transfers hang on local Windows machines
CUSTOM_HF_TEMPERATURE=0.1            # optional — default 0.1
CUSTOM_HF_MAX_TOKENS=512             # optional — default 512
HF_SPACE_QUANTIZATION=int4_cpu       # recommended on CPU-only local machines

# Gemini — required for weekly insights
GEMINI_API_KEY=your_gemini_key_here
GEMINI_MODEL=gemini-2.5-flash

# Fallback if feature vars above are absent
AI_PROVIDER=ollama

# HuggingFace Serverless Inference (alternative)
# CHAT_AI_PROVIDER=huggingface
# HF_API_KEY=your_hf_token
# HF_MODEL=google/gemma-4-E2B-it

# Groq (fallback)
# CHAT_AI_PROVIDER=groq
# GROQ_API_KEY=your_groq_key
# GROQ_MODEL=llama-3.1-8b-instant

# ── OpenRouter — primary cloud gateway (RECOMMENDED) ───────────────────
# All cloud assistant models (GPT, Claude Opus/Sonnet, Llama, etc.) are served
# through OpenRouter with ONE key. BERT (in-server classifier) + local Gemma are
# the only non-OpenRouter models. The picker entries openai_chat / anthropic_opus
# / anthropic_sonnet map to the per-entry slugs below; each falls back to
# OPENROUTER_MODEL when unset, so the menu is never broken.
OPENROUTER_API_KEY=your_openrouter_key          # https://openrouter.ai/keys
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct
OPENROUTER_APP_NAME=LifeSync
OPENROUTER_SITE_URL=https://lifesync.app
OPENROUTER_GPT_MODEL=openai/gpt-5.4-mini
OPENROUTER_CLAUDE_OPUS_MODEL=anthropic/claude-opus-4.8
OPENROUTER_CLAUDE_SONNET_MODEL=anthropic/claude-sonnet-4.6
# To make a cloud model the default responder instead of BERT:
# CHAT_AI_PROVIDER=openrouter

# Direct OpenAI / Anthropic (optional — only if you bypass OpenRouter)
# CHAT_AI_PROVIDER=openai
# OPENAI_API_KEY=your_openai_key
# OPENAI_MODEL=gpt-5.4-mini
# OPENAI_API_BASE_URL=https://api.openai.com/v1
# CHAT_AI_PROVIDER=anthropic
# ANTHROPIC_API_KEY=your_anthropic_key
# ANTHROPIC_OPUS_MODEL=claude-opus-4-8
# ANTHROPIC_SONNET_MODEL=claude-sonnet-4-6
# ANTHROPIC_API_BASE_URL=https://api.anthropic.com/v1

# Ollama (Local Inference)
OLLAMA_MODEL=gemma3:1b
OLLAMA_API_BASE_URL=http://127.0.0.1:11434/v1/chat/completions

# Model picker — local Gemma options (default model is bert_local, set above).
# The "Gemma 3 (local)" / "Gemma 4 (local)" menu entries run on this runtime.
GEMMA_LOCAL_RUNTIME=ollama          # ollama | lmstudio
GEMMA3_MODEL=gemma3                  # tag you pulled, e.g. gemma3 or gemma3:1b
GEMMA4_MODEL=gemma3                  # set to your Gemma 4 tag once pulled

# LM Studio (fully local; OpenAI-compatible server)
# Start the server in LM Studio Developer mode or run: lms server start
# CHAT_AI_PROVIDER=lmstudio
# INSIGHTS_AI_PROVIDER=lmstudio
# AI_PROVIDER=lmstudio
# LM_STUDIO_API_BASE_URL=http://127.0.0.1:1234/v1
# LM_STUDIO_MODEL=lifesync-local
# LM_STUDIO_API_KEY=lm-studio
# LM_STUDIO_REQUEST_TIMEOUT_MS=180000
# AI_INSIGHTS_CACHE_TTL_MS=900000

# LifeSync BERT intent classifier (target model; local HTTP runtime)
# Recommended hybrid: BERT routes chat; deterministic engine owns dashboard
# metrics and narrative. LM Studio is optional only with a separate generator.
# CHAT_AI_PROVIDER=bert_local
# INSIGHTS_AI_PROVIDER=bert_local
# AI_PROVIDER=bert_local
# Local dev: the BERT runtime on this machine.
# BERT_RUNTIME_BASE_URL=http://127.0.0.1:1235
# DEPLOY (Railway/containers): the backend MUST reach BERT over the PRIVATE
# network, not the public *.up.railway.app URL — public service-to-service calls
# fail/hang inside Railway. Use the BERT service's private domain + bound port
# (its Dockerfile binds `--port ${PORT:-8080}`):
#   BERT_RUNTIME_BASE_URL=http://bert.railway.internal:8080
# BERT_MODEL_NAME=bert_best_model_10pct
# BERT_RUNTIME_TIMEOUT_MS=5000
# BERT_RUNTIME_PROVIDER=auto       # auto | directml | cpu
# BERT_CPU_THREADS=6
# BERT_CHUNK_STRIDE=32             # overlap between 128-token chunks
# BERT_MAX_CHUNKS=16               # supports long messages up to API limit
# BERT_MULTI_LABEL_THRESHOLD=0.60  # retain strong secondary intents

# Frontend build — already defaults to Railway URL; set only to override
# VITE_API_URL=https://lifesync-production-fdf9.up.railway.app/api

# --- Encryption ---
ENCRYPTION_KEY=your_encryption_key_min_32_chars!

# --- Admin seed ---
# Used by `npm run seed`. In production the seeder refuses to create the
# default admin unless BOTH are set; in dev it falls back to a known password.
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=

# --- Google Sign-In ---
# Comma-separated list of accepted Google Web client IDs for backend ID-token verification
GOOGLE_AUTH_CLIENT_IDS=your_google_web_client_id

# --- Google Fit (Future Integration) ---
GOOGLE_CLIENT_ID=your_google_fit_client_id
GOOGLE_CLIENT_SECRET=your_google_fit_client_secret

# --- Apple HealthKit (Future Integration) ---
APPLE_HEALTHKIT_KEY=your_apple_healthkit_key

# --- Application URL (for OAuth callbacks) ---
APP_URL=http://localhost:5000

# --- CORS ---
CORS_ORIGIN=http://localhost:5173

# --- Email for OTP ---
# Preferred on hosts that block outbound SMTP (e.g. Railway): Resend HTTP API.
# When RESEND_API_KEY is set, OTP email is sent via https://api.resend.com
# (port 443) instead of SMTP. Get a free key at resend.com.
# RESEND_FROM must be a verified Resend sender; onboarding@resend.dev works for
# testing but only delivers to your own account email until a domain is verified.
RESEND_API_KEY=
RESEND_FROM=LifeSync <onboarding@resend.dev>

# Demo fallback: with NO real email provider, set OTP_DEMO_MODE=true to log the
# verification code to the SERVER logs (e.g. Railway logs — private) and let
# registration proceed. The code is NEVER returned to the client. Use only for
# demos; set RESEND_API_KEY for real sign-ups.
OTP_DEMO_MODE=false

# SMTP fallback (used only when RESEND_API_KEY is empty).
# Leave blank to use Ethereal test emails in development.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=LifeSync
SMTP_FROM_EMAIL=

# --- Assistant context window (larger = smarter, more history/data) ---
# Standard window. A chat request may send context_window: "deep"|"max" to scale
# history + data up per-turn (clamped). Defaults are larger than the old 16/100.
CONTEXT_WINDOW_DAYS=30        # data lookback (1–365)
CONTEXT_MESSAGES=20          # conversation turns kept (4–80)
CONTEXT_MAX_ENTRIES=120      # health/finance rows pulled (20–500)
CONTEXT_RECENT_ENTRIES=16    # recent entries surfaced to the model (6–60)

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# --- Voice (assistant) ---
# Default STT/TTS run in the browser (Web Speech API + speechSynthesis), no keys.
# Set these only to enable server-side cloud transcription via /api/voice/transcribe
# (keeps the provider key off the client). Example: Groq whisper-large-v3.
# VOICE_STT_ENDPOINT=https://api.groq.com/openai/v1/audio/transcriptions
# VOICE_STT_API_KEY=your_stt_key
# VOICE_STT_MODEL=whisper-large-v3
